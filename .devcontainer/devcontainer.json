{
  "name": "gridshield-mvp",
  "version": "1.0.0",
  "description": "Semantic firewall for power grid protection - Deep Packet Inspection on Modbus TCP",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "installZsh": true,
      "configureZshAsDefaultShell": false,
      "username": "codespace",
      "userUid": "1000",
      "userGid": "1000"
    }
  },
  "onCreateCommand": "sudo apt-get update && sudo apt-get install -y libpcap-dev tcpdump && pip install -r requirements.txt",
  "postCreateCommand": "pip install -r requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3"
      }
    }
  },
  "remoteEnv": {
    "PYTHONPATH": "${workspaceFolder}"
  },
  "runArgs": [
    "--cap-add=NET_RAW",
    "--cap-add=NET_ADMIN"
  ]
}
